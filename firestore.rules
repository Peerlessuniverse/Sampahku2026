rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Pengguna hanya bisa membaca dan mengedit data profil/kredit milik mereka sendiri
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Transaksi: 
    // 1. User hanya bisa melihat riwayat transaksi miliknya sendiri
    // 2. User hanya bisa membuat transaksi jika userId di data cocok dengan UID mereka
    match /transactions/{transId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Dokumen lain (jika ada di masa depan): Tolak semua secara default untuk keamanan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
